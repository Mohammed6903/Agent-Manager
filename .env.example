# ── OpenClaw Gateway ─────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=""

OPENCLAW_STATE_DIR="/root/.openclaw"

# ── Service-to-service auth ──────────────────────────────────────────────────
# Shared secret required as `Authorization: Bearer <secret>` on every
# non-public request. Must match the value set on roam-backend AND in
# openclaw.json's agent-manager plugin config (`serviceSecret`).
# Leave empty to disable enforcement (useful during rollout).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
OPENCLAW_SERVICE_SECRET=""
# Previous secret — accepted alongside the current one during rotation.
# Set to the outgoing value while you roll the new one out, then clear.
OPENCLAW_SERVICE_SECRET_PREVIOUS=""

# ── FastAPI Application ──────────────────────────────────────────────────────
ROOT_PATH="/"
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
APP_PORT=8001
SERVER_URL=http://localhost:8001

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://openclaw:openclaw@localhost:5432/openclaw

# ── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
S3_BUCKET_NAME=""

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ── Gmail / Encryption ───────────────────────────────────────────────────────
FERNET_KEY=

# ── Twitter / X ──────────────────────────────────────────────────────────────
TWITTER_API_KEY=""
TWITTER_API_SECRET=""

# ── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""